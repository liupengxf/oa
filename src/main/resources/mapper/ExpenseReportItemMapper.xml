<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.buu.oa.mapper.ExpenseReportItemMapper">

    <select id="selectByReportId" resultType="org.buu.oa.entity.ExpenseReportItem">
        SELECT * FROM expense_report_item WHERE report_id = #{reportId} ORDER BY create_time ASC
    </select>

</mapper>